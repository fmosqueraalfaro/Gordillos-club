# Normaliza finales de línea: LF en el repo, sin importar el SO.
# Evita los warnings "LF will be replaced by CRLF" en Windows.
* text=auto eol=lf

# Archivos binarios: git no los toca.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.svg text
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
